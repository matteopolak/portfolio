---
import { ArrowBigDown } from '@lucide/astro';
const { pathname } = Astro.url;

const links = [
  { name: 'portfolio', href: '/' },
  { name: 'blog', href: '/blog' },
  { name: 'projects', href: '/projects' },
];

const isActive = (href: string) =>
  href === '/'
    ? pathname === '/' || pathname.startsWith('/index')
    : pathname.startsWith(href);
---

<nav class="flex items-center gap-6 mb-8 text-sm">
  {
    links.map(({ name, href }) => (
      <a
        href={href}
        aria-current={isActive(href) ? 'page' : undefined}
        class:list={[
          'font-semibold no-underline hover:no-underline',
          isActive(href)
            ? 'text-base-content'
            : 'text-base-content/60 hover:text-base-content',
        ]}
      >
        {name}
      </a>
    ))
  }
  <a
    href="https://github.com/matteopolak/portfolio/releases/download/resume/resume.pdf"
    class="ml-auto flex items-center gap-1 font-semibold no-underline hover:no-underline text-base-content/60 hover:text-base-content transition-colors"
    >resume <ArrowBigDown class="w-3.5 h-3.5 fill-current" /></a
  >
</nav>
