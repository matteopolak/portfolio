---
import { projects } from '../lib/config';
import { bold } from '../lib/bold';
---

<section>
  <h2>Projects</h2>
  {
    projects.map((project) => (
      <article class="mb-5">
        <div class="flex justify-between items-baseline flex-wrap gap-1 mb-1.5">
          <div class="flex flex-col">
            <a
              class="font-semibold text-base-content hover:text-primary hover:underline"
              href={`https://github.com/${project.github}`}
            >
              {project.title}
            </a>
            {project.tags.length > 0 && (
              <span class="text-sm text-base-content/70">
                {project.tags.join(', ')}
              </span>
            )}
          </div>
          <a
            class="text-sm text-base-content/70 hover:text-primary"
            href={`https://github.com/${project.github}`}
          >
            {project.github}
          </a>
        </div>
        {project.achievements.length > 0 && (
          <ul class="text-sm">
            {project.achievements.map((a) => (
              <li>
                <Fragment set:html={bold(a)} />
              </li>
            ))}
          </ul>
        )}
      </article>
    ))
  }
</section>
