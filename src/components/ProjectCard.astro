---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const date = project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---

<div class="mb-6">
  <div class="flex justify-between items-baseline flex-wrap gap-1 mb-1.5">
    <div class="flex flex-col">
      <a
        class="font-semibold text-base-content hover:text-primary hover:underline"
        href={project.data.website ?? project.data.repository}
      >{project.data.title}</a>
      {project.data.tags.length > 0 && (
        <span class="text-sm text-base-content/70">{project.data.tags.join(', ')}</span>
      )}
    </div>
    <div class="flex items-center gap-3 text-sm">
      {project.data.website && (
        <a href={project.data.website}>website</a>
      )}
      <a href={project.data.repository}>github</a>
      <span class="text-base-content/70">{date}</span>
    </div>
  </div>
  <div class="text-sm"><Content /></div>
</div>
