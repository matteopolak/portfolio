---
import config from '../lib/config';
const { skills } = config;
---

<section>
  <h2>Skills</h2>
  <div class="text-sm flex flex-col gap-1.5">
    <div class="flex gap-3">
      <span class="font-semibold min-w-24 text-base-content/70">Languages</span>
      <span>{skills.languages.join(', ')}</span>
    </div>
    <div class="flex gap-3">
      <span class="font-semibold min-w-24 text-base-content/70">Libraries</span>
      <span>{skills.libraries.join(', ')}</span>
    </div>
    <div class="flex gap-3">
      <span class="font-semibold min-w-24 text-base-content/70">Tools</span>
      <span>{skills.tools.join(', ')}</span>
    </div>
  </div>
</section>
